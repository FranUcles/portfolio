---
import { ui } from '../../i18n/ui';
import Visual from '../Visual.astro';

export interface Props {
  project: any;
  lang: 'es' | 'en';
  reverseFirst?: boolean;
}

const { project, lang, reverseFirst = false } = Astro.props;
const p = project[lang];
const t = ui[lang].project;

const row1Reverse = reverseFirst;
const row2Reverse = !reverseFirst;
---

<div class:list={['split-row', { reverse: row1Reverse }]}>
  <div class="split-visual">
    <Visual media={project.media.row1} label={p.visual1Label} />
  </div>
  <div class="split-text">
    <p class="eyebrow-small">{t.summary}</p>
    <h2>{t.about}</h2>
    <p>{p.overview1}</p>
  </div>
</div>

<div class:list={['split-row', { reverse: row2Reverse }]}>
  <div class="split-visual">
    <Visual media={project.media.row2} label={p.visual2Label} />
  </div>
  <div class="split-text">
    <p class="eyebrow-small">{t.processLabel}</p>
    <h2>{t.process}</h2>
    <p>{p.overview2}</p>
  </div>
</div>

<div class="tech-section">
  <h2>{t.tech}</h2>
  <div class="tag-row">
    {project.tags.map((tag) => <span>{tag}</span>)}
  </div>
</div>