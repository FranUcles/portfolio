---
import { ui } from '../../i18n/ui';
import Visual from '../Visual.astro';

export interface Props {
  project: any;
  lang: 'es' | 'en';
}

const { project, lang } = Astro.props;
const p = project[lang];
const t = ui[lang].project;
---



<div class="carousel-wrap">
  <h2>{t.screenshots}</h2>
  <div class="carousel">
    <div class="carousel-track">
      {project.media.slides.map((m, i) => (
        <div class="carousel-slide">
          <Visual media={m} label={p.slideLabels[i]} />
          <p>{p.slideLabels[i]}</p>
        </div>
      ))}
    </div>
    <button class="carousel-btn prev" aria-label="Prev">←</button>
    <button class="carousel-btn next" aria-label="Next">→</button>
  </div>
  <div class="carousel-dots">
    {project.media.slides.map((_, i) => <button class="carousel-dot" aria-label={`Slide ${i + 1}`} />)}
  </div>
</div>
<div class="cover-content">
  <h2>{t.about}</h2>
  {p.overviews.map((overview) => (<p>{overview}</p>))}
</div>

<div class="tech-section" style="margin-left:auto;margin-right:auto;">
  <h2>{t.tech}</h2>
  <div class="tag-row">
    {project.tags.map((tag) => <span>{tag}</span>)}
  </div>
</div>