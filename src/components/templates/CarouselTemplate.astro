---
import { ui } from '../../i18n/ui';

export interface Props {
  project: any;
  lang: 'es' | 'en';
}

const { project, lang } = Astro.props;
const p = project[lang];
const t = ui[lang].project;
---

<div class="cover-content">
  <h2>{t.about}</h2>
  <p>{p.overview1}</p>
  <p>{p.overview2}</p>
</div>

<div class="carousel-wrap">
  <h2>{t.screenshots}</h2>
  <div class="carousel">
    <div class="carousel-track">
      {
        p.slides.map(([c1, c2, label]) => (
          <div class="carousel-slide" style={`background:linear-gradient(135deg,${c1},${c2});`}>
            {label}
          </div>
        ))
      }
    </div>
    <button class="carousel-btn prev" aria-label="Prev">←</button>
    <button class="carousel-btn next" aria-label="Next">→</button>
  </div>
  <div class="carousel-dots">
    {p.slides.map((_, i) => <button class="carousel-dot" aria-label={`Slide ${i + 1}`} />)}
  </div>
</div>

<div class="tech-section" style="max-width:720px;margin-left:auto;margin-right:auto;">
  <h2>{t.tech}</h2>
  <div class="tag-row">
    {project.tags.map((tag) => <span>{tag}</span>)}
  </div>
</div>
