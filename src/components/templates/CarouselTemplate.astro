---
import { ui } from '../../i18n/ui';
import Carousel from '../Carousel.astro';

export interface Props {
  project: any;
  lang: 'es' | 'en';
}

const { project, lang } = Astro.props;
const p = project[lang];
const t = ui[lang].project;
---



<div class="carousel-wrap">
  <h2>{t.screenshots}</h2>
  <Carousel slides={p.slides} />
</div>
<div class="cover-content">
  <h2>{t.about}</h2>
  {p.overviews.map((overview) => (<p>{overview}</p>))}
</div>