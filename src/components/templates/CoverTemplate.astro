---
import { ui } from '../../i18n/ui';
import Visual from '../Visual.astro';

export interface Props {
  project: any;
  lang: 'es' | 'en';
}

const { project, lang } = Astro.props;
const p = project[lang];
const t = ui[lang].project;
---

<div class="cover-banner">
  <Visual media={project.media.cover} label={`${p.title} — ${t.screenshots}`} />
</div>
<div class="cover-content">
  <h2>{t.about}</h2>
  <p>{p.overview1}</p>
  <p>{p.overview2}</p>
  <blockquote class="pull-quote">{p.quote}</blockquote>
  <div class="stat-row">
    {p.stats.map(([value, label]) => (
      <div class="stat">
        <strong>{value}</strong>
        <span>{label}</span>
      </div>
    ))}
  </div>
</div>