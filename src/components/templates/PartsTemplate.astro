---
import { ui } from '../../i18n/ui';
import Visual from '../Visual.astro';
import OverviewBlocks from './partials/OverviewBlocks.astro';

export interface Props {
  project: any;
  lang: 'es' | 'en';
}

const { project, lang } = Astro.props;
const p = project[lang];
const t = ui[lang].project;
---

<div class="cover-content">
  <h2>{t.about}</h2>
  <OverviewBlocks blocks={p.about} />
</div>
{p.parts.map((part) => (
  <>
    <div class="cover-content">
      <h2>{part.title}</h2>
      <OverviewBlocks blocks={part.overviews} />
    </div>
    {part.media && <div class="cover-banner">
      <Visual media={part.media.cover} label={`${part.media.title}`} />
    </div>}
  </>
))}
